{
  "manifest_version": 3,
  "name": "ADHD Reader",
  "description": "A faster reading extension that applies bionic-style word highlighting.",
  "version": "1.0.0",
  "icons": {
    "16": "icon/icon16.svg",
    "48": "icon/icon48.svg",
    "128": "icon/icon128.svg"
  },
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ADHD Reader",
    "default_icon": {
      "16": "icon/icon16.svg",
      "48": "icon/icon48.svg",
      "128": "icon/icon128.svg"
    }
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/bionic.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}